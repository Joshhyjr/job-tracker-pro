# Hosted Gemini credentials stay server-side and must never use the VITE_ prefix.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
# Use a long random value that the operator enters into the dashboard per browser session.
AI_INSIGHTS_ACCESS_TOKEN=""

# Ollama remains the privacy-first fallback when hosted insights are unavailable.
VITE_OLLAMA_MODEL="qwen2.5:7b"

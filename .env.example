# Hosted Gemini credentials stay server-side and must never use the VITE_ prefix.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Firebase Admin verifies signed-in Google ID tokens inside the Vercel function.
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
# Preserve the service-account newlines as escaped \n sequences when the host requires a single line.
FIREBASE_ADMIN_PRIVATE_KEY=""

# Firebase web configuration is public by design; Firestore Security Rules enforce data access.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Contact form email forwarding stays server-side; do not use VITE_ for these.
RESEND_API_KEY=""
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
CONTACT_TO_EMAIL=""

# Ollama remains the privacy-first fallback when hosted insights are unavailable.
VITE_OLLAMA_MODEL="qwen2.5:7b"
